{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist"
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"],
  "paths": {
    "*": ["node_modules/*"], 
    "src/*": ["./src/*"],
    "routes/*": ["./src/routes/*"],
    "controller/*":[".src/controller/*"]
  }
}
